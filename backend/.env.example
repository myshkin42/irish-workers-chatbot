# Anthropic (Claude) - for chat responses
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI - for embeddings (Anthropic doesn't have embedding API)
OPENAI_API_KEY=sk-...

# Pinecone
PINECONE_API_KEY=...
