# Anthropic (Claude) - for chat responses
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI - for embeddings (Anthropic doesn't have embedding API)
OPENAI_API_KEY=sk-...

# Pinecone
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=irish-workers-chatbot

# Optional: API security
API_BEARER_TOKEN=your-secret-token-here

# Optional: separate Irish company-check API
COMPANY_CHECK_API_URL=https://irish-company-check-api.fly.dev
COMPANY_CHECK_API_TOKEN=company-check-api-token-here
COMPANY_CHECK_LOOKUP_TTL_MINUTES=30

# Environment
ENVIRONMENT=development
